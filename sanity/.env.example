SANITY_STUDIO_PROJECT_ID=s88o8sjb

# Default CLI dataset (Studio uses workspace switcher: production at /, development at /development)
SANITY_STUDIO_DATASET=production

# Write token for seeding verification fixtures and running migrations (development dataset)
# Must have Editor role or higher — deploy tokens cannot mutate documents.
# SANITY_API_TOKEN=

# Deploy token for headless CLI (sanity deploy). Copy to .env.local — never commit.
# SANITY_AUTH_TOKEN=
