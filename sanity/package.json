{
	"name": "sanity",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "sanity dev",
		"build": "sanity build",
		"check": "tsc -p tsconfig.json --noEmit",
		"deploy": "sanity deploy",
		"start": "sanity start",
		"datasets:list": "sanity dataset list",
		"datasets:ensure": "sanity dataset list | grep -q '^development$' || sanity dataset create development --visibility public",
		"fixtures:seed": "tsx fixtures/verification/seed.ts",
		"fixtures:seed:dry-run": "tsx fixtures/verification/seed.ts --dry-run",
		"reviewseed:seed": "tsx fixtures/review-seed/seed.ts",
		"reviewseed:seed:dry-run": "tsx fixtures/review-seed/seed.ts --dry-run",
		"reviewseed:delete": "tsx fixtures/review-seed/seed.ts --delete",
		"schema:extract": "sanity schema extract --workspace production --enforce-required-fields --path schema.json",
		"typegen": "pnpm schema:extract && sanity typegen generate",
		"migrate:location-hierarchy": "tsx migrations/location-hierarchy-migrate.ts",
		"migrate:location-hierarchy:dry-run": "tsx migrations/location-hierarchy-migrate.ts --dry-run",
		"migrate:review-items": "tsx migrations/review-items-migrate.ts",
		"migrate:review-items:dry-run": "tsx migrations/review-items-migrate.ts --dry-run",
		"migrate:source-provenance-keys": "tsx migrations/source-provenance-keys-migrate.ts",
		"migrate:source-provenance-keys:dry-run": "tsx migrations/source-provenance-keys-migrate.ts --dry-run",
		"migrate:unset-media-rights": "tsx migrations/unset-media-rights-migrate.ts",
		"migrate:unset-media-rights:dry-run": "tsx migrations/unset-media-rights-migrate.ts --dry-run",
		"migrate:unset-caption": "tsx migrations/unset-caption-migrate.ts",
		"migrate:unset-caption:dry-run": "tsx migrations/unset-caption-migrate.ts --dry-run",
		"migrate:prune-media-privacy-review-items": "tsx migrations/prune-media-privacy-review-items-migrate.ts",
		"migrate:prune-media-privacy-review-items:dry-run": "tsx migrations/prune-media-privacy-review-items-migrate.ts --dry-run",
		"migrate:related-content": "tsx migrations/related-content-migrate.ts",
		"migrate:related-content:dry-run": "tsx migrations/related-content-migrate.ts --dry-run",
		"migrate:micro-location-unset": "tsx migrations/micro-location-unset-migrate.ts",
		"migrate:micro-location-unset:dry-run": "tsx migrations/micro-location-unset-migrate.ts --dry-run",
		"migrate:unset-listing-map-fields": "tsx migrations/unset-listing-map-fields-migrate.ts",
		"migrate:unset-listing-map-fields:dry-run": "tsx migrations/unset-listing-map-fields-migrate.ts --dry-run",
		"migrate:unset-hero-headline": "tsx migrations/unset-hero-headline-migrate.ts",
		"migrate:unset-hero-headline:dry-run": "tsx migrations/unset-hero-headline-migrate.ts --dry-run",
		"migrate:unset-hero-image": "tsx migrations/unset-hero-image-migrate.ts",
		"migrate:unset-hero-image:dry-run": "tsx migrations/unset-hero-image-migrate.ts --dry-run",
		"migrate:fix-gallery-keys": "tsx migrations/fix-gallery-keys-migrate.ts",
		"migrate:fix-gallery-keys:dry-run": "tsx migrations/fix-gallery-keys-migrate.ts --dry-run",
		"migrate:unset-specs-parking-garage": "tsx migrations/unset-specs-parking-garage-migrate.ts",
		"migrate:unset-specs-parking-garage:dry-run": "tsx migrations/unset-specs-parking-garage-migrate.ts --dry-run",
		"migrate:prune-epc-review-items": "tsx migrations/prune-epc-review-items-migrate.ts",
		"migrate:prune-epc-review-items:dry-run": "tsx migrations/prune-epc-review-items-migrate.ts --dry-run",
		"migrate:listing-title": "tsx migrations/listing-title-migrate.ts",
		"migrate:listing-title:dry-run": "tsx migrations/listing-title-migrate.ts --dry-run",
		"migrate:content-to-marketing": "tsx migrations/content-to-marketing-migrate.ts",
		"migrate:content-to-marketing:dry-run": "tsx migrations/content-to-marketing-migrate.ts --dry-run",
		"migrate:taxonomy-parent-refs": "tsx migrations/taxonomy-parent-refs-migrate.ts",
		"migrate:taxonomy-parent-refs:dry-run": "tsx migrations/taxonomy-parent-refs-migrate.ts --dry-run",
		"migrate:taxonomy-dotted-ids": "tsx migrations/taxonomy-dotted-ids-migrate.ts",
		"migrate:taxonomy-dotted-ids:dry-run": "tsx migrations/taxonomy-dotted-ids-migrate.ts --dry-run",
		"seed:location-taxonomy": "tsx migrations/seed-location-taxonomy.ts",
		"seed:location-taxonomy:dry-run": "tsx migrations/seed-location-taxonomy.ts --dry-run",
		"seed:overview-lorem": "tsx migrations/seed-overview-lorem.ts",
		"seed:overview-lorem:dry-run": "tsx migrations/seed-overview-lorem.ts --dry-run",
		"wipe:location-taxonomy": "tsx migrations/wipe-location-taxonomy.ts",
		"wipe:location-taxonomy:dry-run": "tsx migrations/wipe-location-taxonomy.ts --dry-run",
		"migrate:curated-heroes": "tsx migrations/curated-heroes-migrate.ts",
		"migrate:curated-heroes:dry-run": "tsx migrations/curated-heroes-migrate.ts --dry-run",
		"migrate:set-nueva-andalucia-hero": "tsx migrations/set-nueva-andalucia-hero-migrate.ts",
		"migrate:set-nueva-andalucia-hero:dry-run": "tsx migrations/set-nueva-andalucia-hero-migrate.ts --dry-run",
		"migrate:golf-course-community": "tsx migrations/golf-course-community-migrate.ts",
		"migrate:golf-course-community:dry-run": "tsx migrations/golf-course-community-migrate.ts --dry-run",
		"test": "vitest run"
	},
	"dependencies": {
		"@sanity/client": "^7.14.0",
		"@sanity/icons": "^3.7.4",
		"@sanity/ui": "^3.2.0",
		"@sanity/vision": "^5.28.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"sanity": "^5.28.0",
		"styled-components": "^6.3.12",
		"rxjs": "^7.8.2"
	},
	"devDependencies": {
		"@types/react": "^19.2.0",
		"tsx": "^4.20.3",
		"typescript": "^5.9.3",
		"vitest": "^4.1.7"
	}
}
