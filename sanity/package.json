{
	"name": "sanity",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "sanity dev",
		"build": "sanity build",
		"deploy": "sanity deploy",
		"start": "sanity start",
		"datasets:list": "sanity dataset list",
		"datasets:ensure": "sanity dataset list | grep -q '^development$' || sanity dataset create development --visibility public",
		"fixtures:seed": "tsx fixtures/verification/seed.ts",
		"fixtures:seed:dry-run": "tsx fixtures/verification/seed.ts --dry-run",
		"schema:extract": "sanity schema extract --workspace production --enforce-required-fields --path schema.json",
		"typegen": "pnpm schema:extract && sanity typegen generate",
		"migrate:location-hierarchy": "tsx migrations/location-hierarchy-migrate.ts",
		"migrate:location-hierarchy:dry-run": "tsx migrations/location-hierarchy-migrate.ts --dry-run",
		"migrate:review-items": "tsx migrations/review-items-migrate.ts",
		"migrate:review-items:dry-run": "tsx migrations/review-items-migrate.ts --dry-run",
		"migrate:image-rights": "tsx migrations/image-rights-migrate.ts",
		"migrate:image-rights:dry-run": "tsx migrations/image-rights-migrate.ts --dry-run",
		"migrate:related-content": "tsx migrations/related-content-migrate.ts",
		"migrate:related-content:dry-run": "tsx migrations/related-content-migrate.ts --dry-run",
		"migrate:micro-location-unset": "tsx migrations/micro-location-unset-migrate.ts",
		"migrate:micro-location-unset:dry-run": "tsx migrations/micro-location-unset-migrate.ts --dry-run",
		"migrate:listing-title": "tsx migrations/listing-title-migrate.ts",
		"migrate:listing-title:dry-run": "tsx migrations/listing-title-migrate.ts --dry-run",
		"migrate:content-to-marketing": "tsx migrations/content-to-marketing-migrate.ts",
		"migrate:content-to-marketing:dry-run": "tsx migrations/content-to-marketing-migrate.ts --dry-run",
		"migrate:taxonomy-parent-refs": "tsx migrations/taxonomy-parent-refs-migrate.ts",
		"migrate:taxonomy-parent-refs:dry-run": "tsx migrations/taxonomy-parent-refs-migrate.ts --dry-run",
		"migrate:taxonomy-dotted-ids": "tsx migrations/taxonomy-dotted-ids-migrate.ts",
		"migrate:taxonomy-dotted-ids:dry-run": "tsx migrations/taxonomy-dotted-ids-migrate.ts --dry-run",
		"seed:location-taxonomy": "tsx migrations/seed-location-taxonomy.ts",
		"seed:location-taxonomy:dry-run": "tsx migrations/seed-location-taxonomy.ts --dry-run",
		"wipe:location-taxonomy": "tsx migrations/wipe-location-taxonomy.ts",
		"wipe:location-taxonomy:dry-run": "tsx migrations/wipe-location-taxonomy.ts --dry-run",
		"test": "vitest run"
	},
	"dependencies": {
		"@sanity/client": "^7.14.0",
		"@sanity/icons": "^3.7.4",
		"@sanity/ui": "^3.2.0",
		"@sanity/vision": "^5.28.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"sanity": "^5.28.0",
		"styled-components": "^6.3.12",
		"rxjs": "^7.8.2"
	},
	"devDependencies": {
		"@types/react": "^19.2.0",
		"tsx": "^4.20.3",
		"typescript": "^5.9.3",
		"vitest": "^4.1.7"
	}
}
