PUBLIC_SANITY_PROJECT_ID=s88o8sjb

# Local development and Vercel Preview deployments should use the development dataset.
# Set this to production only for production builds/deployments.
PUBLIC_SANITY_DATASET=development

# Sanity Studio URL for visual editing / live preview (match active workspace basePath)
PUBLIC_SANITY_STUDIO_URL=http://localhost:3333/development

# Server-only read token for draft preview (Viewer role or higher)
# SANITY_API_READ_TOKEN=

# --- Google reviews ---------------------------------------------------------
# Featurable Classic (v1) widget ID. The widget must be bound to the Google Business
# Profile location; while it is unbound, Featurable serves placeholder reviews flagged
# with `example: true`, which the provider rejects outright — so the section stays dark
# rather than shipping fake praise.
#
# Unset in dev: fixtures render instead, so the section is visible locally.
# Unset in production: the section does not render at all. That is the intended state
# until the profile is verified, bound, and has collected at least three reviews.
# FEATURABLE_WIDGET_ID=

# Force fixture reviews on a deployed preview (never set this in production).
# REVIEWS_FIXTURES=true

# Google Place ID for the Business Profile. Builds the "Read all reviews" link:
#   https://search.google.com/local/reviews?placeid=<id>
# — Google's login-free reviews panel.
#
# This is built from the Place ID on purpose and never taken from the Featurable payload:
# Featurable's `profileUrl` is derived from Google's writeAReviewUri, which redirects to an
# accounts.google.com sign-in wall asking the visitor to *leave* a review. Do not "fix" the
# link by using the vendor's URL.
#
# Unset: the section renders normally, just without a "Read all reviews" link.
# Find the ID at https://developers.google.com/maps/documentation/places/web-service/place-id
# GOOGLE_PLACE_ID=
